# Kopiere diese Datei nach secrets.yaml und passe die Werte an:
#   cp secrets.yaml.example secrets.yaml

wifi_ssid: "MeinWLAN"
wifi_password: "mein-wlan-passwort"

# API-Schlüssel für die ESPHome-HA-Verbindung
# Generiere einen neuen mit: esphome wizard
api_key: "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="

# OTA-Passwort für Firmware-Updates über WiFi
ota_password: "mein-ota-passwort"
